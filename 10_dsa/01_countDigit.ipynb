   "source": [
    "def countdigit(n):\n",
    "    n=abs(n)\n",
    "    if n==0:\n",
    "        return 1\n",
    "    count =0\n",
    "    while n>0:\n",
    "        n = n//10\n",
    "        count +=1 \n",
    "    return count\n",
    "\n",
    "num = -432345\n",
    "result = countdigit(num)\n",
    "print(result)"
   ]
