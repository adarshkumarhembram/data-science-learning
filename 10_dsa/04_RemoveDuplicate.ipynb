   "source": [
    "def Removedup(nums):\n",
    "    x = 0\n",
    "    for i in range(1,len(nums)):\n",
    "        if nums[i] !=nums[x]:\n",
    "            x = x+1\n",
    "            nums[x] = nums[i]\n",
    "    return x+1\n",
    "nums = [0,0,1,1,1,2,2,3,3,4]\n",
    "result = Removedup(nums)\n",
    "print(result)"
   ]
