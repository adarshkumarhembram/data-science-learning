   "source": [
    "def Palindrome(n):\n",
    "    if n<0:\n",
    "        n=-n\n",
    "    rev = 0\n",
    "    while n>0:\n",
    "        digit= n%10\n",
    "        rev = (10*rev) + digit\n",
    "        n = n//10\n",
    "    return rev\n",
    "\n",
    "num = -121\n",
    "result= Palindrome(num)\n",
    "print(result)\n"
   ]
  },
